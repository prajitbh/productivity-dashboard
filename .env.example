# Get this from your Neon project dashboard -> Connection Details
# Use the "pooled" connection string for serverless/Vercel deployments.
DATABASE_URL="postgresql://user:password@ep-example-12345.us-east-2.aws.neon.tech/neondb?sslmode=require"

# --- TMDB (for movie/show poster auto-fetch on Habits > TV) ---
# Free key from https://www.themoviedb.org/settings/api — see README for steps.
TMDB_API_KEY=""

# --- NextAuth (required for Outlook calendar sign-in) ---
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Your local dev URL — in production on Vercel, set this to your deployed URL instead.
NEXTAUTH_URL="http://localhost:3000"

# --- Microsoft Azure AD app (for live Outlook calendar sync) ---
# See README for how to register a free Azure app and get these three values.
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID="common"
